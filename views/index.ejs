<%- include('partials/header') %>

<!-- Hero Section -->
<section class="relative h-screen flex items-center justify-center overflow-hidden -mt-20">
    <!-- Background Video -->
    <div class="absolute inset-0 w-full h-full z-0 overflow-hidden pointer-events-none">
        <!-- Para trocar o vídeo, substitua '5WQAUk9XMXE' pelo ID do seu vídeo do YouTube (nos dois lugares do link abaixo) -->
        <iframe 
            class="absolute top-1/2 left-1/2 w-[100vw] h-[56.25vw] min-h-[100vh] min-w-[177.77vh] -translate-x-1/2 -translate-y-1/2 opacity-100"
            src="https://www.youtube.com/embed/5WQAUk9XMXE?autoplay=1&mute=1&loop=1&playlist=5WQAUk9XMXE&controls=0&showinfo=0&rel=0&modestbranding=1" 
            frameborder="0" 
            allow="autoplay; encrypted-media" 
            allowfullscreen>
        </iframe>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 text-center px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto">
        <!-- Removido o texto STOCK a pedido do usuário -->
        <p class="text-xl md:text-2xl text-gray-300 mb-10 font-light tracking-wide animate-on-scroll delay-100 mt-32">
            Editor de Vídeo | Apaixonado por contar histórias visuais
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4 animate-on-scroll delay-200">
            <a href="/portfolio" class="px-8 py-4 rounded-full bg-white text-black font-semibold hover:bg-gray-200 transition-all duration-300 transform hover:scale-105">
                Ver Portfólio
            </a>
        </div>
    </div>
</section>

<!-- Featured Work Preview -->
<section class="py-24 bg-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-end mb-12 animate-on-scroll">
            <div>
                <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Trabalhos em Destaque</h2>
                <p class="text-gray-400 mt-2">Algumas das minhas edições recentes.</p>
            </div>
            <a href="/portfolio" class="hidden md:block text-red-500 hover:text-red-400 font-medium transition-colors">Ver Todos &rarr;</a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Project 1 (Custom Player) -->
            <div class="custom-yt-player group relative rounded-2xl overflow-hidden aspect-video animate-on-scroll delay-100 shadow-[0_0_15px_rgba(220,38,38,0)] hover:shadow-[0_0_25px_rgba(220,38,38,0.3)] transition-all duration-500 bg-black" data-video-id="6-WsdoOFwLQ">
                <!-- YouTube Player Container -->
                <div class="absolute inset-0 w-full h-full pointer-events-none overflow-hidden">
                    <div class="yt-player-container w-full h-full scale-[1.05]"></div>
                </div>
                
                <!-- Poster Image to hide YouTube's initial UI -->
                <img src="https://img.youtube.com/vi/6-WsdoOFwLQ/maxresdefault.jpg" alt="Video Cover" class="absolute inset-0 w-full h-full object-cover z-10 transition-opacity duration-500 yt-poster pointer-events-none">
                
                <!-- Clickable Overlay to toggle play/pause -->
                <div class="absolute inset-0 z-20 cursor-pointer click-overlay"></div>
                
                <!-- Custom Controls Overlay -->
                <div class="absolute bottom-0 left-0 right-0 z-30 bg-gradient-to-t from-black/90 via-black/50 to-transparent p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col gap-2">
                    <!-- Timeline -->
                    <input type="range" class="w-full h-1.5 bg-gray-600 rounded-lg appearance-none cursor-pointer accent-red-500 video-timeline hover:h-2 transition-all" min="0" max="100" value="0" step="0.1">
                    
                    <!-- Buttons -->
                    <div class="flex items-center justify-between text-white mt-1">
                        <div class="flex items-center gap-4">
                            <button class="play-pause-btn hover:text-red-500 transition-colors focus:outline-none">
                                <svg class="w-7 h-7 play-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                <svg class="w-7 h-7 pause-icon hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
                            </button>
                            <div class="text-sm font-mono time-display select-none">00:00 / 00:00</div>
                        </div>
                        <div class="flex items-center gap-4">
                            <button class="mute-btn hover:text-red-500 transition-colors focus:outline-none">
                                <svg class="w-6 h-6 volume-on-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
                                <svg class="w-6 h-6 volume-off-icon hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
                            </button>
                            <button class="fullscreen-btn hover:text-red-500 transition-colors focus:outline-none">
                                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>
                            </button>
                        </div>
                    </div>
                </div>
                
                <!-- Big Play Button Overlay (Center) -->
                <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-30">
                    <div class="big-play-btn bg-red-600/80 rounded-full p-4 text-white opacity-80 transition-opacity duration-300">
                        <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                    </div>
                </div>
            </div>
            <!-- Project 2 (Custom Player) -->
            <div class="custom-yt-player group relative rounded-2xl overflow-hidden aspect-video animate-on-scroll delay-200 shadow-[0_0_15px_rgba(220,38,38,0)] hover:shadow-[0_0_25px_rgba(220,38,38,0.3)] transition-all duration-500 bg-black" data-video-id="vOdT5hJ-ACs">
                <!-- YouTube Player Container -->
                <div class="absolute inset-0 w-full h-full pointer-events-none overflow-hidden">
                    <div class="yt-player-container w-full h-full scale-[1.05]"></div>
                </div>
                
                <!-- Poster Image to hide YouTube's initial UI -->
                <img src="https://img.youtube.com/vi/vOdT5hJ-ACs/maxresdefault.jpg" alt="Video Cover" class="absolute inset-0 w-full h-full object-cover z-10 transition-opacity duration-500 yt-poster pointer-events-none">
                
                <!-- Clickable Overlay to toggle play/pause -->
                <div class="absolute inset-0 z-20 cursor-pointer click-overlay"></div>
                
                <!-- Custom Controls Overlay -->
                <div class="absolute bottom-0 left-0 right-0 z-30 bg-gradient-to-t from-black/90 via-black/50 to-transparent p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col gap-2">
                    <!-- Timeline -->
                    <input type="range" class="w-full h-1.5 bg-gray-600 rounded-lg appearance-none cursor-pointer accent-red-500 video-timeline hover:h-2 transition-all" min="0" max="100" value="0" step="0.1">
                    
                    <!-- Buttons -->
                    <div class="flex items-center justify-between text-white mt-1">
                        <div class="flex items-center gap-4">
                            <button class="play-pause-btn hover:text-red-500 transition-colors focus:outline-none">
                                <svg class="w-7 h-7 play-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                <svg class="w-7 h-7 pause-icon hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
                            </button>
                            <div class="text-sm font-mono time-display select-none">00:00 / 00:00</div>
                        </div>
                        <div class="flex items-center gap-4">
                            <button class="mute-btn hover:text-red-500 transition-colors focus:outline-none">
                                <svg class="w-6 h-6 volume-on-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
                                <svg class="w-6 h-6 volume-off-icon hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
                            </button>
                            <button class="fullscreen-btn hover:text-red-500 transition-colors focus:outline-none">
                                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>
                            </button>
                        </div>
                    </div>
                </div>
                
                <!-- Big Play Button Overlay (Center) -->
                <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-30">
                    <div class="big-play-btn bg-red-600/80 rounded-full p-4 text-white opacity-80 transition-opacity duration-300">
                        <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                    </div>
                </div>
            </div>
        </div>
        <div class="mt-8 text-center md:hidden">
            <a href="/portfolio" class="text-red-500 hover:text-red-400 font-medium transition-colors">Ver Todos &rarr;</a>
        </div>
    </div>
</section>

<%- include('partials/footer') %>

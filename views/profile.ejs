<%- include('partials/header') %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 animate-on-scroll">
    
    <!-- Profile Header -->
    <div class="bg-[#111] rounded-2xl border border-white/5 overflow-hidden mb-8 relative">
        <!-- Cover Photo -->
        <div class="h-48 w-full bg-gradient-to-r from-red-900 via-black to-red-900 relative" id="profile-banner" style="background-image: url('https://i.pinimg.com/1200x/87/2e/ed/872eed84abb883692b8aa78dd78f33fe.jpg'); background-size: cover; background-position: center;">
            <div class="absolute inset-0 bg-black/30"></div>
        </div>
        
        <div class="px-8 pb-8 relative">
            <div class="flex flex-col sm:flex-row items-center sm:items-end -mt-16 sm:-mt-20 mb-6">
                <!-- Avatar -->
                <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full border-4 border-[#111] overflow-hidden bg-[#1a1a1a] shrink-0 z-10">
                    <img id="profile-photo" src="https://i.pinimg.com/736x/17/87/d3/1787d3e3ebf0d9aa274e5bba64ad82f5.jpg" alt="Profile" class="w-full h-full object-cover" referrerPolicy="no-referrer">
                </div>
                
                <div class="mt-4 sm:mt-0 sm:ml-6 flex-grow text-center sm:text-left z-10">
                    <h1 id="profile-name" class="text-3xl font-bold text-white">stock</h1>
                    <p class="text-red-400 font-medium" id="profile-role">Video Editor & Motion Designer</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Dashboard Content -->
    <div class="grid grid-cols-1 gap-8">
        
        <!-- Sidebar -->
        <div class="space-y-8 animate-on-scroll delay-100">
            <div class="bg-[#111] rounded-2xl border border-white/5 p-6">
                <h3 class="text-lg font-bold text-white mb-4">Contato</h3>
                <ul class="space-y-3 text-gray-400 text-sm">
                    <li class="flex items-center">

<%- include('partials/header') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 animate-on-scroll">
    <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">Vamos Trabalhar Juntos</h1>
        <p class="text-gray-400 max-w-2xl mx-auto text-lg">Estou pronto para ajudar a editar seu próximo vídeo. Escolha um plano ou entre em contato para um orçamento personalizado.</p>
    </div>

    <div id="success-message" class="max-w-2xl mx-auto mb-12 bg-green-500/10 border border-green-500/20 rounded-xl p-6 text-center hidden">
        <h3 class="text-green-400 font-bold text-xl mb-2">Solicitação Enviada com Sucesso!</h3>
        <p class="text-gray-300">Obrigado por entrar em contato. Retornarei em breve.</p>
    </div>

    <!-- Pricing Plans -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
        <!-- Basic -->
        <div class="bg-[#141414] rounded-2xl p-8 border border-white/5 hover:border-red-500/30 transition-all duration-300 flex flex-col animate-on-scroll delay-100 hover:-translate-y-2">
            <h3 class="text-xl font-semibold text-gray-300 mb-2">Básico</h3>
            <div class="text-4xl font-bold text-white mb-6">R$150<span class="text-lg text-gray-500 font-normal">/vídeo</span></div>
            <ul class="space-y-4 mb-8 flex-grow">
                <li class="flex items-start text-gray-400">
                    <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Até 3 minutos
                </li>
                <li class="flex items-start text-gray-400">
                    <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Cortes simples & transições
                </li>
                <li class="flex items-start text-gray-400">
                    <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    2 Revisões
                </li>
            </ul>
            <button class="plan-btn w-full py-3 rounded-lg bg-white/5 hover:bg-white/10 text-white font-medium transition-colors border border-white/10" data-plan="Básico">Selecionar Básico</button>
        </div>

        <!-- Intermediate -->
        <div class="bg-gradient-to-b from-[#1a1a1a] to-[#141414] rounded-2xl p-8 border border-red-500/30 relative transform md:-translate-y-4 shadow-[0_0_30px_rgba(220,38,38,0.15)] flex flex-col animate-on-scroll delay-200 hover:shadow-[0_0_40px_rgba(220,38,38,0.25)] transition-all duration-300">
            <div class="absolute top-0 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-gradient-to-r from-red-600 to-red-800 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Mais Popular</div>
            <h3 class="text-xl font-semibold text-red-400 mb-2">Padrão</h3>
            <div class="text-4xl font-bold text-white mb-6">R$400<span class="text-lg text-gray-500 font-normal">/vídeo</span></div>
            <ul class="space-y-4 mb-8 flex-grow">
                <li class="flex items-start text-gray-300">
                    <svg class="w-5 h-5 text-red-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Até 10 minutos
                </li>
                <li class="flex items-start text-gray-300">
                    <svg class="w-5 h-5 text-red-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Correção de cor
                </li>
                <li class="flex items-start text-gray-300">
                    <svg class="w-5 h-5 text-red-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Textos e efeitos
                </li>
                <li class="flex items-start text-gray-300">
                    <svg class="w-5 h-5 text-red-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    4 Revisões
                </li>
            </ul>
            <button class="plan-btn w-full py-3 rounded-lg bg-gradient-to-r from-red-600 to-red-800 hover:from-red-500 hover:to-red-700 text-white font-medium transition-colors shadow-lg" data-plan="Padrão">Selecionar Padrão</button>
        </div>

        <!-- Advanced -->
        <div class="bg-[#141414] rounded-2xl p-8 border border-white/5 hover:border-red-500/30 transition-all duration-300 flex flex-col animate-on-scroll delay-300 hover:-translate-y-2">
            <h3 class="text-xl font-semibold text-gray-300 mb-2">Premium</h3>
            <div class="text-4xl font-bold text-white mb-6">R$750+<span class="text-lg text-gray-500 font-normal">/projeto</span></div>
            <ul class="space-y-4 mb-8 flex-grow">
                <li class="flex items-start text-gray-400">
                    <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Duração personalizada
                </li>
                <li class="flex items-start text-gray-400">
                    <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Edição avançada
                </li>
                <li class="flex items-start text-gray-400">
                    <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Design de som & mixagem
                </li>
                <li class="flex items-start text-gray-400">
                    <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Revisões Ilimitadas
                </li>
            </ul>
            <button class="plan-btn w-full py-3 rounded-lg bg-white/5 hover:bg-white/10 text-white font-medium transition-colors border border-white/10" data-plan="Premium">Contatar para Orçamento</button>
        </div>
    </div>

    <!-- Contact Form -->
    <div class="max-w-3xl mx-auto bg-[#111] rounded-2xl p-8 md:p-12 border border-white/5 animate-on-scroll delay-200">
        <h2 class="text-2xl font-bold mb-6">Solicitação de Projeto Personalizado</h2>
        <form id="quote-form" class="space-y-6">
            <input type="hidden" id="selected-plan" value="Personalizado">
            
            <div>
                <label for="description" class="block text-sm font-medium text-gray-400 mb-2">Descrição do Projeto</label>
                <textarea id="description" name="description" rows="4" required class="w-full bg-[#1a1a1a] border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-all resize-none" placeholder="Descreva o que você precisa..."></textarea>
            </div>

            <button type="submit" class="w-full py-4 rounded-lg bg-white text-black font-bold text-lg hover:bg-gray-200 transition-colors">
                Enviar Solicitação
            </button>
        </form>
    </div>
</div>

<script type="module">
    import { auth, db, addDoc, collection, serverTimestamp } from '/js/firebase-init.js';

    // Handle plan selection
    document.querySelectorAll('.plan-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const plan = e.target.getAttribute('data-plan');
            document.getElementById('selected-plan').value = plan;
            document.getElementById('description').placeholder = `Descreva os detalhes para o plano ${plan}...`;
            document.getElementById('description').focus();
            
            // Scroll to form
            document.getElementById('quote-form').scrollIntoView({ behavior: 'smooth' });
        });
    });

    document.getElementById('quote-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const user = auth.currentUser;
        if (!user) {
            alert('Você precisa estar logado para solicitar um orçamento.');
            window.location.href = '/login';
            return;
        }

        const plan = document.getElementById('selected-plan').value;
        const details = document.getElementById('description').value;

        try {
            await addDoc(collection(db, 'quotes'), {
                userId: user.uid,
                plan: plan,
                details: details,
                status: 'pending',
                createdAt: new Date().toISOString()
            });

            document.getElementById('success-message').classList.remove('hidden');
            document.getElementById('quote-form').reset();
            document.getElementById('selected-plan').value = 'Personalizado';
            
            setTimeout(() => {
                window.location.href = '/profile';
            }, 2000);

        } catch (error) {
            console.error("Erro ao enviar orçamento:", error);
            alert("Erro ao enviar solicitação: " + error.message);
        }
    });
</script>

<%- include('partials/footer') %>

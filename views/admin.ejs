<%- include('partials/header') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 animate-on-scroll">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-bold text-white">Painel Administrativo</h1>
            <p class="text-gray-400 mt-1">Gerencie orçamentos e mensagens dos clientes.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 h-[70vh]">
        <!-- Sidebar: Users/Chats List -->
        <div class="bg-[#111] rounded-2xl border border-white/5 flex flex-col overflow-hidden">
            <div class="p-4 border-b border-white/5">
                <h2 class="text-lg font-bold text-white">Clientes</h2>
            </div>
            <div id="users-list" class="flex-grow overflow-y-auto p-2 space-y-1">
                <p class="text-gray-400 text-sm p-4 text-center">Carregando...</p>
            </div>
        </div>

        <!-- Main Chat/Details Area -->
        <div class="lg:col-span-2 bg-[#111] rounded-2xl border border-white/5 flex flex-col overflow-hidden relative">
            <div id="chat-empty-state" class="absolute inset-0 flex flex-col items-center justify-center text-gray-500 z-10 bg-[#111]">
                <svg class="w-16 h-16 mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                <p>Selecione um cliente para ver detalhes e mensagens</p>
            </div>

            <!-- Chat Header -->
            <div class="p-4 border-b border-white/5 flex justify-between items-center bg-[#1a1a1a]">
                <div class="flex items-center gap-3">
                    <img id="current-chat-avatar" src="" alt="" class="w-10 h-10 rounded-full object-cover hidden">
                    <div>
                        <h2 id="current-chat-name" class="text-lg font-bold text-white"></h2>
                        <p id="current-chat-email" class="text-xs text-gray-400"></p>
                    </div>
                </div>
            </div>

            <!-- Chat Messages & Quotes -->
            <div id="chat-messages" class="flex-grow overflow-y-auto p-6 space-y-6">
                <!-- Messages will be injected here -->
            </div>

            <!-- Chat Input -->
            <div class="p-4 border-t border-white/5 bg-[#1a1a1a]">
                <form id="chat-form" class="flex gap-2">
                    <input type="text" id="chat-input" placeholder="Digite uma mensagem..." class="flex-grow px-4 py-3 bg-[#111] border border-white/10 rounded-lg text-white focus:outline-none focus:border-red-500 transition-colors" disabled>
                    <button type="submit" id="chat-submit" class="px-6 py-3 bg-red-600 hover:bg-red-700 text-white rounded-lg font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                        Enviar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script type="module">
    import { auth, db, onAuthStateChanged, collection, query, where, onSnapshot, doc, getDoc, addDoc, orderBy, serverTimestamp, updateDoc } from '/js/firebase-init.js';

    let currentUserId = null;
    let selectedClientId = null;
    let unsubscribeMessages = null;
    let unsubscribeQuotes = null;

    onAuthStateChanged(auth, async (user) => {
        if (!user) {
            window.location.href = '/login';
            return;
        }

        // Verify Admin Role
        const userDoc = await getDoc(doc(db, 'users', user.uid));
        const isDefaultAdmin = user.email === 'rafaekrafaelturbo@gmail.com';
        
        if (!isDefaultAdmin && (!userDoc.exists() || userDoc.data().role !== 'admin')) {
            alert('Acesso negado. Apenas administradores.');
            window.location.href = '/';
            return;
        }

        // Auto-upgrade default admin if their document still says 'client'
        if (isDefaultAdmin && userDoc.exists() && userDoc.data().role !== 'admin') {
            try {
                await updateDoc(doc(db, 'users', user.uid), { role: 'admin' });
            } catch (e) {
                console.error("Erro ao promover para admin:", e);
            }
        }
        
        currentUserId = user.uid;
        loadClients();
    });

    function loadClients() {
        const q = query(collection(db, 'users'), where('role', '==', 'client'));
        onSnapshot(q, (snapshot) => {
            const list = document.getElementById('users-list');
            list.innerHTML = '';
            
            if (snapshot.empty) {
                list.innerHTML = '<p class="text-gray-400 text-sm p-4 text-center">Nenhum cliente encontrado.</p>';
                return;
            }

            snapshot.forEach((doc) => {
                const client = doc.data();
                const avatar = client.photoURL || `https://ui-avatars.com/api/?name=${encodeURIComponent(client.name)}&background=random`;
                
                const div = document.createElement('div');
                div.className = `flex items-center gap-3 p-3 rounded-lg cursor-pointer transition-colors ${selectedClientId === client.uid ? 'bg-red-500/10 border border-red-500/20' : 'hover:bg-white/5 border border-transparent'}`;
                div.innerHTML = `
                    <img src="${avatar}" class="w-10 h-10 rounded-full object-cover shrink-0">
                    <div class="overflow-hidden">
                        <h4 class="text-white font-medium truncate">${client.name}</h4>
                        <p class="text-xs text-gray-400 truncate">${client.email}</p>
                    </div>
                `;
                
                div.addEventListener('click', () => selectClient(client));
                list.appendChild(div);
            });
        });
    }

    function selectClient(client) {
        selectedClientId = client.uid;
        document.getElementById('chat-empty-state').classList.add('hidden');
        
        // Update Header
        const avatarEl = document.getElementById('current-chat-avatar');
        avatarEl.src = client.photoURL || `https://ui-avatars.com/api/?name=${encodeURIComponent(client.name)}&background=random`;
        avatarEl.classList.remove('hidden');
        document.getElementById('current-chat-name').textContent = client.name;
        document.getElementById('current-chat-email').textContent = client.email;

        // Enable Input
        document.getElementById('chat-input').disabled = false;
        document.getElementById('chat-submit').disabled = false;

        // Re-render user list to show selection
        loadClients();

        // Load Data
        loadClientData(client.uid);
    }

    function loadClientData(clientId) {
        const messagesContainer = document.getElementById('chat-messages');
        messagesContainer.innerHTML = '<div class="text-center text-gray-500 py-4">Carregando histórico...</div>';

        if (unsubscribeMessages) unsubscribeMessages();
        if (unsubscribeQuotes) unsubscribeQuotes();

        let quotesData = [];
        let messagesData = [];

        function renderChat() {
            messagesContainer.innerHTML = '';
            
            // Render Quotes First (as system messages)
            quotesData.forEach(quote => {
                const date = quote.createdAt ? new Date(quote.createdAt).toLocaleString('pt-BR') : '';
                messagesContainer.innerHTML += `
                    <div class="flex justify-center my-4">
                        <div class="bg-[#1a1a1a] border border-white/10 rounded-lg p-4 max-w-md w-full text-center">
                            <span class="text-xs text-gray-500 uppercase tracking-wider font-bold">Solicitação de Orçamento</span>
                            <h4 class="text-white font-bold mt-1">${quote.plan}</h4>
                            <p class="text-sm text-gray-400 mt-2">${quote.details}</p>
                            <div class="mt-4 flex justify-center gap-2">
                                <select class="quote-status-select bg-[#111] border border-white/10 text-white text-sm rounded px-2 py-1 focus:outline-none focus:border-red-500" data-id="${quote.id}">
                                    <option value="pending" ${quote.status === 'pending' ? 'selected' : ''}>Pendente</option>
                                    <option value="accepted" ${quote.status === 'accepted' ? 'selected' : ''}>Aceito</option>
                                    <option value="completed" ${quote.status === 'completed' ? 'selected' : ''}>Concluído</option>
                                    <option value="rejected" ${quote.status === 'rejected' ? 'selected' : ''}>Recusado</option>
                                </select>
                            </div>
                            <p class="text-xs text-gray-500 mt-3">${date}</p>
                        </div>
                    </div>
                `;
            });

            // Render Messages
            messagesData.forEach(msg => {
                const isAdmin = msg.senderId === currentUserId;
                const alignClass = isAdmin ? 'justify-end' : 'justify-start';
                const bubbleClass = isAdmin ? 'bg-red-600 text-white rounded-br-none' : 'bg-[#1a1a1a] border border-white/10 text-gray-200 rounded-bl-none';
                const date = msg.createdAt ? new Date(msg.createdAt).toLocaleTimeString('pt-BR', {hour: '2-digit', minute:'2-digit'}) : '';

                messagesContainer.innerHTML += `
                    <div class="flex ${alignClass} mb-4">
                        <div class="max-w-[70%] rounded-2xl px-4 py-2 ${bubbleClass}">
                            <p class="text-sm">${msg.text}</p>
                            <p class="text-[10px] opacity-70 text-right mt-1">${date}</p>
                        </div>
                    </div>
                `;
            });

            messagesContainer.scrollTop = messagesContainer.scrollHeight;

            // Add event listeners to status selects
            document.querySelectorAll('.quote-status-select').forEach(select => {
                select.addEventListener('change', async (e) => {
                    const quoteId = e.target.getAttribute('data-id');
                    const newStatus = e.target.value;
                    try {
                        await updateDoc(doc(db, 'quotes', quoteId), { status: newStatus });
                    } catch (error) {
                        console.error("Erro ao atualizar status:", error);
                        alert("Erro ao atualizar status.");
                    }
                });
            });
        }

        // Listen to Quotes
        const qQuotes = query(collection(db, 'quotes'), where('userId', '==', clientId));
        unsubscribeQuotes = onSnapshot(qQuotes, (snapshot) => {
            quotesData = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
            // Sort quotes by date locally since we can't easily compound query without index
            quotesData.sort((a, b) => new Date(a.createdAt) - new Date(b.createdAt));
            renderChat();
        });

        // Listen to Messages
        const qMessages = query(collection(db, 'messages'), where('userId', '==', clientId), orderBy('createdAt', 'asc'));
        unsubscribeMessages = onSnapshot(qMessages, (snapshot) => {
            messagesData = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
            renderChat();
        });
    }

    // Send Message
    document.getElementById('chat-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!selectedClientId || !currentUserId) return;

        const input = document.getElementById('chat-input');
        const content = input.value.trim();
        if (!content) return;

        input.value = '';
        input.focus();

        try {
            await addDoc(collection(db, 'messages'), {
                userId: selectedClientId,
                senderId: currentUserId,
                text: content,
                createdAt: new Date().toISOString()
            });
        } catch (error) {
            console.error("Erro ao enviar mensagem:", error);
            alert("Erro ao enviar mensagem: " + error.message);
        }
    });

</script>

<%- include('partials/footer') %>

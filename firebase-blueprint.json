{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application (client or admin)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["client", "admin"], "description": "User role" },
        "photoURL": { "type": "string", "description": "Profile photo URL" },
        "bannerURL": { "type": "string", "description": "Profile banner URL" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Quote": {
      "title": "Quote",
      "description": "A quote or contract request from a client",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the client who requested the quote" },
        "plan": { "type": "string", "description": "The plan requested" },
        "details": { "type": "string", "description": "Details of the request" },
        "status": { "type": "string", "enum": ["pending", "accepted", "completed", "rejected"], "description": "Status of the quote" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "plan", "details", "status", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message between admin and client",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The client ID this message belongs to" },
        "senderId": { "type": "string", "description": "The ID of the user who sent the message" },
        "text": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/quotes/{quoteId}": {
      "schema": { "$ref": "#/entities/Quote" },
      "description": "Stores quotes and contracts"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores chat messages"
    }
  }
}
